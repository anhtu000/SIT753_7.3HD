{
  "name": "sit753-7-3hd-flow-retail",
  "version": "1.0.0",
  "description": "FLOW retail e-commerce app with Jenkins CI/CD pipeline",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node index.js",
    "init-db": "node createDB.js",
    "test": "cross-env NODE_ENV=test SKIP_EMAIL=true STRIPE_SECRET_KEY=sk_test_dummy_key_for_local_tests SESSION_SECRET=test_secret jest --runInBand --forceExit --coverage",
    "build": "npm ci && npm run init-db"
  },
  "keywords": [
    "node",
    "express",
    "ejs",
    "sqlite",
    "jenkins",
    "docker",
    "devops"
  ],
  "author": "Andy Vu",
  "license": "ISC",
  "dependencies": {
    "body-parser": "^2.2.2",
    "dotenv": "^17.2.3",
    "ejs": "^4.0.1",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "morgan": "^1.10.1",
    "nodemailer": "^7.0.13",
    "prom-client": "^15.1.3",
    "sqlite3": "^5.1.7",
    "stripe": "^20.3.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "jest-junit": "^16.0.0",
    "supertest": "^7.1.4"
  },
  "jest": {
    "testEnvironment": "node",
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "reports/junit",
          "outputName": "jest.xml"
        }
      ]
    ],
    "coverageDirectory": "coverage"
  }
}
